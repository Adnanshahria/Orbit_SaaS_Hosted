# ─── Security Headers (all routes) ───
/*
  X-Robots-Tag: index, follow
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com; img-src 'self' data: blob: https: http:; connect-src 'self' https://api.groq.com https://api.imgbb.com https://orbitsaas.cloud https://*.turso.io wss://*.turso.io https://cdn.jsdelivr.net https://unpkg.com https://lottie.host https://fonts.googleapis.com https://fonts.gstatic.com; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# ─── Static assets: 1 year cache ───
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ─── Images/media: 1 day browser, 1 year CDN ───
/*.png
  Cache-Control: public, max-age=86400, s-maxage=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=86400, s-maxage=31536000, immutable
/*.jpeg
  Cache-Control: public, max-age=86400, s-maxage=31536000, immutable
/*.webp
  Cache-Control: public, max-age=86400, s-maxage=31536000, immutable
/*.svg
  Cache-Control: public, max-age=86400, s-maxage=31536000, immutable
/*.gif
  Cache-Control: public, max-age=86400, s-maxage=31536000, immutable

# ─── Sitemap & robots ───
/sitemap.xml
  Content-Type: application/xml
  Cache-Control: public, max-age=3600

/robots.txt
  Content-Type: text/plain
  Cache-Control: public, max-age=3600
